{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost",
  "Blockchain": {
    "RpcUrl": "",
    "PrivateKey": ""
  },
  "Storage": {
    "Provider": "File",
    "Path": "data/storage"
  },
  "Scanner": {
    "ScanIntervalSeconds": 12,
    "MaxBlockAge": 2,
    "MaxConcurrentDexCalls": 5,
    "MinimumProfitThreshold": 0.01,
    "SlippageTolerance": 0.005,
    "MaxRetryCount": 3
  }
}